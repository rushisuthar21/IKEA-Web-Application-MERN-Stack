<%- include('../partials/header') %>

<div class="container mt-4 mb-5">
  <h2 class="page-title" data-aos="fade-up">Admin Dashboard</h2>

  <!-- 🔍 Search Bar -->
  <form method="GET" action="/products" class="content-panel mb-4 d-flex gap-2 flex-wrap align-items-center" data-aos="fade-up">
    <input type="text" name="search" class="form-control" placeholder="Search products..." value="<%= search || '' %>" style="max-width: 280px;">

    <select name="category" class="form-select" style="max-width: 200px;">
      <option value="all" <%= category === 'all' ? 'selected' : '' %>>All Categories</option>
      <% categories.forEach(c => { %>
        <option value="<%= c %>" <%= category === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>

    <button class="btn btn-outline-secondary" type="submit"><i class='bx bx-filter-alt'></i> Filter</button>

    <a href="/products/add" class="btn btn-primary ms-auto"><i class='bx bx-plus'></i> Add Product</a>
  </form>

  <!-- 📦 Product Table -->
  <div class="table-responsive content-panel" data-aos="fade-up">
    <table class="table table-modern align-middle mb-0">
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price ($)</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
          <tr><td colspan="5">
            <div class="empty-state">
              <div class="empty-icon"><i class='bx bx-package'></i></div>
              <h6>No products found.</h6>
            </div>
          </td></tr>
        <% } else { %>
          <% products.forEach(product => { %>
            <tr>
              <td>
                <% if (product.image) { %>
                  <img src="<%= product.image %>" style="width: 56px; height: 56px; object-fit: cover; border-radius: var(--radius-sm);">
                <% } else { %> N/A <% } %>
              </td>
              <td class="fw-semibold"><%= product.name %></td>
              <td><span class="status-badge status-Shipped"><%= product.category %></span></td>
              <td class="fw-bold text-success">
                $<%= (product.price !== undefined && product.price !== null)
                      ? Number(product.price).toFixed(2)
                      : '0.00' %>
              </td>
              <td class="d-flex gap-2">
                <a href="/products/edit/<%= product._id %>" class="btn btn-sm btn-warning"><i class='bx bx-edit'></i> Edit</a>
                <form method="POST" action="/products/delete/<%= product._id %>" style="display: inline-block;" onsubmit="return confirm('Delete this product?');">
                  <button class="btn btn-sm btn-danger"><i class='bx bx-trash'></i> Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
