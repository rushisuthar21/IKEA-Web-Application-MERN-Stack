<%- include('../partials/header') %>

<div class="container mt-4 mb-5">
  <h2 class="page-title" data-aos="fade-up">Customer List</h2>

  <% if (!users.length) { %>
    <div class="empty-state content-panel" data-aos="fade-up">
      <div class="empty-icon"><i class='bx bx-user-x'></i></div>
      <h5>No customers found</h5>
    </div>
  <% } else { %>
    <div class="table-responsive content-panel" data-aos="fade-up">
      <table class="table table-modern align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Address</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td class="fw-semibold"><%= u.name %></td>
              <td><%= u.email %></td>
              <td><%= u.address %></td>
              <td>
                <form method="POST" action="/admin/customers/delete/<%= u._id %>" onsubmit="return confirm('Are you sure you want to delete this customer and all their orders?')">
                  <button class="btn btn-sm btn-danger"><i class='bx bx-trash'></i> Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
