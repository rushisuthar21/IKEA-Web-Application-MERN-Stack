<%- include('../partials/header') %>

<div class="container mt-4 mb-5" style="max-width: 760px;">
  <h2 class="page-title" data-aos="fade-up">Order Details</h2>

  <div class="content-panel" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0"><i class='bx bxs-user-detail'></i> Customer Information</h5>
      <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
    </div>
    <div class="row mb-2">
      <div class="col-sm-6"><p class="mb-1"><strong>Name:</strong> <%= order.customerDetails.name %></p></div>
      <div class="col-sm-6"><p class="mb-1"><strong>Email:</strong> <%= order.customerDetails.email %></p></div>
      <div class="col-sm-6"><p class="mb-1"><strong>Phone:</strong> <%= order.customerDetails.phone %></p></div>
      <div class="col-sm-6"><p class="mb-1"><strong>Address:</strong> <%= order.customerDetails.address %></p></div>
    </div>

    <hr>
    <h5><i class='bx bx-list-ul'></i> Order Summary</h5>
    <ul class="mb-3">
      <% order.items.forEach(i => { %>
        <li><%= i.productId?.name %> — <%= i.quantity %> x $<%= i.productId?.price %></li>
      <% }) %>
    </ul>

    <p class="mb-1"><strong>Total:</strong> <span class="text-success fw-bold">$<%= order.totalAmount.toFixed(2) %></span></p>
    <p class="mb-1"><strong>Order Date:</strong> <%= new Date(order.createdAt).toLocaleString() %></p>
  </div>

  <a href="/orders/admin/orders" class="btn btn-secondary mt-4">← Back to Orders</a>
</div>

<%- include('../partials/footer') %>
