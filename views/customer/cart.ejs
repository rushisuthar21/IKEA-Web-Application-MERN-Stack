<%- include('../partials/header') %>

<div class="container mt-4 mb-5">
  <h2 class="page-title" data-aos="fade-up">My Cart</h2>

  <% if (!cart || !cart.items.length) { %>
    <div class="empty-state content-panel" data-aos="fade-up">
      <div class="empty-icon"><i class='bx bx-cart'></i></div>
      <h5>Your cart is empty</h5>
      <p>Looks like you haven't added anything yet.</p>
      <a href="/products" class="btn btn-primary mt-2"><i class='bx bx-store'></i> Continue Shopping</a>
    </div>
  <% } else { %>
    <div class="table-responsive content-panel" data-aos="fade-up">
      <table class="table table-modern align-middle mb-0">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Subtotal</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% let total = 0; %>
          <% cart.items.forEach(item => {
               const product = item.productId;
               const itemTotal = product.price * item.quantity;
               total += itemTotal;
          %>
            <tr>
              <td class="fw-semibold"><%= product.name %></td>
              <td>$<%= product.price %></td>
              <td>
                <!-- ✅ Quantity Update Form -->
                <form method="POST" action="/cart/update" class="d-flex align-items-center qty-stepper" novalidate>
                  <input type="hidden" name="productId" value="<%= product._id %>">
                  <button type="button" class="btn btn-outline-secondary btn-sm me-1" onclick="this.parentNode.querySelector('input[name=quantity]').stepDown()">−</button>
                  <input
                    type="number"
                    name="quantity"
                    min="1"
                    required
                    value="<%= item.quantity %>"
                    class="form-control form-control-sm text-center"
                    style="width: 60px;"
                  >
                  <button type="button" class="btn btn-outline-secondary btn-sm ms-1" onclick="this.parentNode.querySelector('input[name=quantity]').stepUp()">+</button>
              </td>
              <td class="fw-bold text-success">$<%= itemTotal.toFixed(2) %></td>
              <td class="d-flex gap-2 flex-wrap">
                  <button class="btn btn-sm btn-primary">Update</button>
                </form>

                <!-- ❌ Remove Form -->
                <form method="POST" action="/cart/remove">
                  <input type="hidden" name="productId" value="<%= product._id %>">
                  <button class="btn btn-sm btn-outline-danger"><i class='bx bx-trash'></i> Remove</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <tr>
            <td colspan="3" class="text-end"><strong>Total:</strong></td>
            <td colspan="2"><strong class="text-success fs-5">$<%= total.toFixed(2) %></strong></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ✅ Action Buttons -->
    <div class="d-flex justify-content-between mt-4" data-aos="fade-up">
      <a href="/products" class="btn btn-secondary">← Continue Shopping</a>
      <a href="/orders/checkout" class="btn btn-success">Proceed to Checkout →</a>
    </div>
  <% } %>
</div>

<script src="/js/validation.js"></script>
<%- include('../partials/footer') %>
