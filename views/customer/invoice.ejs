<%- include('../partials/header') %>
<div class="container mt-4 mb-5" style="max-width: 800px;">
  <h2 class="page-title center" data-aos="fade-up"><i class='bx bx-receipt'></i> Invoice</h2>

  <div class="invoice-card" data-aos="fade-up">
    <div class="row mb-4">
      <div class="col-sm-6">
        <p class="mb-1"><strong>Name:</strong> <%= order.customerDetails.name %></p>
        <p class="mb-1"><strong>Email:</strong> <%= order.customerDetails.email %></p>
      </div>
      <div class="col-sm-6">
        <p class="mb-1"><strong>Phone:</strong> <%= order.customerDetails.phone %></p>
        <p class="mb-1"><strong>Address:</strong> <%= order.customerDetails.address %></p>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-modern mb-4">
        <thead><tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Total</th></tr></thead>
        <tbody>
          <% order.items.forEach(item => {
            const product = item.productId;
            const total = product.price * item.quantity;
          %>
            <tr>
              <td><%= product.name %></td>
              <td><%= item.quantity %></td>
              <td>$<%= product.price %></td>
              <td>$<%= total.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="text-end">
      <span class="invoice-total"><i class='bx bx-dollar-circle'></i> Total: $<%= order.totalAmount.toFixed(2) %></span>
    </div>
  </div>

  <div class="text-center">
    <a href="/products" class="btn btn-primary mt-4">Continue Shopping</a>
  </div>
</div>
<%- include('../partials/footer') %>
