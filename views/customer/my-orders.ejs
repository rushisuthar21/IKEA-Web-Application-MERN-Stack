<%- include('../partials/header') %>

<div class="container mt-4 mb-5">
  <h2 class="page-title" data-aos="fade-up">My Orders</h2>

  <% if (!orders.length) { %>
    <div class="empty-state content-panel" data-aos="fade-up">
      <div class="empty-icon"><i class='bx bx-package'></i></div>
      <h5>No orders yet</h5>
      <p>You haven't placed any orders yet.</p>
      <a href="/products" class="btn btn-primary mt-2">Start Shopping</a>
    </div>
  <% } else { %>
    <div class="table-responsive content-panel" data-aos="fade-up">
      <table class="table table-modern align-middle mb-0">
        <thead>
          <tr>
            <th>Order Date</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
            <th>Invoice</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
            <tr>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>
                <ul class="mb-0 ps-3">
                  <% order.items.forEach(i => { %>
                    <li><%= i.productId?.name %> x <%= i.quantity %></li>
                  <% }) %>
                </ul>
              </td>
              <td class="fw-bold">$<%= order.totalAmount.toFixed(2) %></td>
              <td><span class="status-badge status-<%= order.status %>"><%= order.status %></span></td>
              <td>
                <a href="/orders/invoice?orderId=<%= order._id %>" class="btn btn-sm btn-outline-primary"><i class='bx bx-receipt'></i> View Invoice</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
