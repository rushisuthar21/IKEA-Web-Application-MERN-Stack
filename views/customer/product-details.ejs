<%- include('../partials/header') %>

<div class="container mt-4 mb-5">
  <div class="row g-4 align-items-start">
    <div class="col-md-5" data-aos="fade-right">
      <div class="content-panel p-2">
        <img src="<%= product.image %>" alt="<%= product.name %>" class="img-fluid rounded" style="width: 100%; object-fit: cover; border-radius: var(--radius);">
      </div>
    </div>
    <div class="col-md-7" data-aos="fade-left">
      <span class="status-badge status-Shipped mb-2 d-inline-block"><%= product.category %></span>
      <h2 class="fw-bold" style="color: var(--ink);"><%= product.name %></h2>
      <p class="price fs-4 d-inline-block">$<%= product.price.toFixed(2) %></p>
      <p class="text-muted mt-3" style="line-height: 1.7;"><%= product.description %></p>

      <form method="POST" action="/cart/add" class="mt-4">
        <input type="hidden" name="productId" value="<%= product._id %>">
        <button class="btn btn-primary btn-lg px-4"><i class='bx bx-cart-add'></i> Add to Cart</button>
      </form>

      <a href="/products" class="btn btn-link mt-3 ps-0">← Back to Shop</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
